# Keystone Notary Group LLC - Environment Variables
# Copy this file to .env and fill in your actual values

# Google Services
GOOGLE_CALENDAR_API_KEY=your_google_calendar_api_key_here
GOOGLE_WORKSPACE_CLIENT_ID=your_google_workspace_client_id_here
GOOGLE_WORKSPACE_CLIENT_SECRET=your_google_workspace_client_secret_here

# Email Service (Choose one)
# Option 1: SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=contact@keystonenotarygroup.com

# Option 2: AWS SES
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SES_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_SES_FROM_EMAIL=contact@keystonenotarygroup.com

# Option 3: Mailgun
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=mg.keystonenotarygroup.com
MAILGUN_FROM_EMAIL=contact@keystonenotarygroup.com

# Google reCAPTCHA v3
RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# Business Contact
BUSINESS_EMAIL=contact@keystonenotarygroup.com
BUSINESS_PHONE=+12673099000
NOTIFICATION_EMAIL=admin@keystonenotarygroup.com

# Application Settings
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://www.keystonenotarygroup.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5
