<section class="spacing-map surface-section surface-elevated" aria-labelledby="spacingMapTitle">
  <div class="spacing-map-content-centered">
    <h2 id="spacingMapTitle">Spacing Key</h2>
    <p class="lead">The modular spacing scale keeps gutters, stacking rhythm, and component breathing room consistent from cards to full-width sections.</p>
  </div>

  <div class="layout-container section-inner spacing-inner">
    <div class="spacing-map-content">
      <ul class="spacing-scale" role="list">
        <li>
          <span class="spacing-swatch" style="--spacing-size: var(--space-2xs);"></span>
          <code>--space-2xs</code>
          <span>Tight label padding & icon nudges</span>
        </li>
        <li>
          <span class="spacing-swatch" style="--spacing-size: var(--space-xs);"></span>
          <code>--space-xs</code>
          <span>Compact gaps & control groupings</span>
        </li>
        <li>
          <span class="spacing-swatch" style="--spacing-size: var(--space-sm);"></span>
          <code>--space-sm</code>
          <span>Default input padding</span>
        </li>
        <li>
          <span class="spacing-swatch" style="--spacing-size: var(--space-md);"></span>
          <code>--space-md</code>
          <span>Card interior gutters</span>
        </li>
        <li>
          <span class="spacing-swatch" style="--spacing-size: var(--space-lg);"></span>
          <code>--space-lg</code>
          <span>Stack spacing between headings</span>
        </li>
        <li>
          <span class="spacing-swatch" style="--spacing-size: var(--space-xl);"></span>
          <code>--space-xl</code>
          <span>Grid gutters & media padding</span>
        </li>
        <li>
          <span class="spacing-swatch" style="--spacing-size: var(--space-2xl);"></span>
          <code>--space-2xl</code>
          <span>Card exterior margins</span>
        </li>
        <li>
          <span class="spacing-swatch" style="--spacing-size: var(--space-3xl);"></span>
          <code>--space-3xl</code>
          <span>Section top rhythm</span>
        </li>
        <li>
          <span class="spacing-swatch" style="--spacing-size: var(--space-4xl);"></span>
          <code>--space-4xl</code>
          <span>Hero & feature padding</span>
        </li>
      </ul>
    </div>
  </div>
</section>
