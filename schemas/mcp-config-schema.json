{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MCP Configuration Schema",
  "description": "JSON Schema for Model Context Protocol (MCP) server configuration",
  "type": "object",
  "required": ["version", "environments"],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri",
      "description": "URI of the JSON Schema resource"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Configuration version following semantic versioning"
    },
    "metadata": {
      "type": "object",
      "description": "Configuration metadata",
      "properties": {
        "description": {
          "type": "string",
          "description": "Human-readable description of the configuration"
        },
        "lastUpdated": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of last update"
        },
        "author": {
          "type": "string",
          "description": "Author or entity responsible for the configuration"
        }
      },
      "additionalProperties": true
    },
    "environments": {
      "type": "object",
      "description": "Environment-specific configurations",
      "patternProperties": {
        "^[a-z][a-z0-9-]*$": {
          "type": "object",
          "description": "Environment configuration (e.g., development, staging, production)",
          "properties": {
            "extends": {
              "type": "string",
              "description": "Name of environment to extend from"
            },
            "overrides": {
              "type": "object",
              "description": "Properties that override the extended environment"
            },
            "servers": {
              "type": "object",
              "description": "MCP server configurations",
              "patternProperties": {
                "^[a-z][a-z0-9-]*$": {
                  "type": "object",
                  "required": ["url"],
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "default": true,
                      "description": "Whether this server is enabled"
                    },
                    "url": {
                      "type": "string",
                      "format": "uri",
                      "description": "MCP server endpoint URL"
                    },
                    "timeout": {
                      "type": "integer",
                      "minimum": 1000,
                      "maximum": 300000,
                      "default": 30000,
                      "description": "Request timeout in milliseconds"
                    },
                    "retryAttempts": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 10,
                      "default": 3,
                      "description": "Number of retry attempts for failed requests"
                    },
                    "retryDelay": {
                      "type": "integer",
                      "minimum": 0,
                      "default": 1000,
                      "description": "Delay between retry attempts in milliseconds"
                    },
                    "headers": {
                      "type": "object",
                      "description": "HTTP headers to include with requests",
                      "additionalProperties": {
                        "type": "string"
                      }
                    },
                    "features": {
                      "type": "object",
                      "description": "Server feature flags and configurations",
                      "properties": {
                        "rateLimiting": {
                          "type": "boolean",
                          "default": true,
                          "description": "Enable rate limiting"
                        },
                        "caching": {
                          "type": "boolean",
                          "default": true,
                          "description": "Enable response caching"
                        },
                        "compression": {
                          "type": "boolean",
                          "default": true,
                          "description": "Enable request/response compression"
                        },
                        "logging": {
                          "type": "object",
                          "properties": {
                            "level": {
                              "type": "string",
                              "enum": ["debug", "info", "warn", "error"],
                              "default": "info"
                            },
                            "enabled": {
                              "type": "boolean",
                              "default": true
                            }
                          }
                        }
                      },
                      "additionalProperties": true
                    },
                    "validation": {
                      "type": "object",
                      "description": "Request/response validation rules",
                      "properties": {
                        "requireAuth": {
                          "type": "boolean",
                          "default": true,
                          "description": "Require authentication for this server"
                        },
                        "allowedMethods": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "enum": ["GET", "POST", "PUT", "DELETE", "PATCH"]
                          },
                          "description": "Allowed HTTP methods"
                        },
                        "maxResponseSize": {
                          "type": "string",
                          "pattern": "^\\d+(?:KB|MB|GB)?$",
                          "description": "Maximum allowed response size"
                        }
                      }
                    }
                  },
                  "additionalProperties": true
                }
              },
              "additionalProperties": false
            },
            "security": {
              "type": "object",
              "description": "Security configuration for the environment",
              "properties": {
                "tokenRotation": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "default": false
                    },
                    "rotationInterval": {
                      "type": "string",
                      "pattern": "^\\d+(?:m|h|d|w)$",
                      "description": "Token rotation interval (e.g., 30d, 24h, 7d)"
                    },
                    "preWarningDays": {
                      "type": "integer",
                      "minimum": 0,
                      "description": "Days before expiration to warn about rotation"
                    }
                  }
                },
                "encryption": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "default": false
                    },
                    "algorithm": {
                      "type": "string",
                      "enum": ["AES-256-GCM", "AES-256-CBC", "ChaCha20-Poly1305"],
                      "description": "Encryption algorithm to use"
                    }
                  }
                },
                "validation": {
                  "type": "object",
                  "properties": {
                    "strictSchema": {
                      "type": "boolean",
                      "default": false
                    },
                    "validateOnLoad": {
                      "type": "boolean",
                      "default": false
                    }
                  }
                }
              }
            },
            "monitoring": {
              "type": "object",
              "description": "Monitoring and health check configuration",
              "properties": {
                "healthChecks": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "default": false
                    },
                    "interval": {
                      "type": "integer",
                      "minimum": 10000,
                      "description": "Health check interval in milliseconds"
                    },
                    "timeout": {
                      "type": "integer",
                      "minimum": 1000,
                      "description": "Health check timeout in milliseconds"
                    }
                  }
                },
                "metrics": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "default": false
                    },
                    "collectionInterval": {
                      "type": "integer",
                      "minimum": 1000,
                      "description": "Metrics collection interval in milliseconds"
                    }
                  }
                },
                "alerts": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "default": false
                    },
                    "channels": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "enum": ["log", "email", "webhook", "slack"]
                      },
                      "description": "Alert delivery channels"
                    },
                    "emailConfig": {
                      "type": "object",
                      "properties": {
                        "recipients": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "format": "email"
                          }
                        },
                        "smtpServer": {
                          "type": "string",
                          "description": "SMTP server configuration"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "defaults": {
      "type": "object",
      "description": "Default values applied to all environments",
      "properties": {
        "environment": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Default environment name"
        },
        "server": {
          "type": "object",
          "description": "Default server configuration",
          "properties": {
            "timeout": {
              "type": "integer",
              "minimum": 1000,
              "maximum": 300000,
              "default": 30000
            },
            "retryAttempts": {
              "type": "integer",
              "minimum": 0,
              "maximum": 10,
              "default": 3
            },
            "features": {
              "type": "object",
              "properties": {
                "rateLimiting": {
                  "type": "boolean",
                  "default": true
                },
                "caching": {
                  "type": "boolean",
                  "default": true
                },
                "compression": {
                  "type": "boolean",
                  "default": true
                }
              }
            }
          }
        }
      }
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "version": "2.0.0",
      "environments": {
        "development": {
          "servers": {
            "huggingface": {
              "enabled": true,
              "url": "${HUGGINGFACE_MCP_URL}",
              "timeout": 30000,
              "retryAttempts": 3,
              "headers": {
                "Authorization": "Bearer ${HUGGINGFACE_API_TOKEN}",
                "Content-Type": "application/json"
              }
            }
          }
        }
      },
      "defaults": {
        "environment": "development"
      }
    }
  ]
}
