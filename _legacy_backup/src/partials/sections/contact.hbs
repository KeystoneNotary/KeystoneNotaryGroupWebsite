<section id="contact" class="contact-section surface-section surface-deep">
  <div class="contact-content-centered">
    <span class="section-label">Contact</span>
    <h2>Get in Touch</h2>
    <p class="lead">Send the details, we’ll confirm logistics and arrive prepared.</p>
  </div>

  <div class="layout-container section-inner contact-inner">
    <div class="contact-grid">
      <div class="contact-card glass-card">
        <h3>Message our team</h3>
        <p class="contact-intro">We respond within one business day—or sooner for urgent appointments.</p>
        <form class="contact-form" id="contactForm">
          <div id="contactFormMessages" aria-live="polite" aria-atomic="true"></div>
          <label class="form-field">
            <span class="sr-only">Your Name *</span>
            <input type="text" name="name" placeholder="Name *" autocomplete="name" required>
          </label>
          <label class="form-field">
            <span class="sr-only">Email *</span>
            <input type="email" name="email" placeholder="Email *" autocomplete="email" required>
          </label>
          <label class="form-field">
            <span class="sr-only">How can we help? *</span>
            <textarea name="message" placeholder="How can we help? *" rows="5" required></textarea>
          </label>
          <button type="submit" class="glass-button">Send Message</button>
        </form>
        <p class="microcopy">By submitting, you agree to receive scheduling communications from Keystone Notary Group LLC.</p>
      </div>
      <div class="contact-card glass-card contact-assist">
        <h3>Concierge scheduling</h3>
        <ul class="contact-options">
          <li><a href="tel:+12673099000">Call (267) 309-9000</a><span>Daily 7am – 9pm</span></li>
          <li><a href="mailto:contact@keystonenotarygroup.com">contact@keystonenotarygroup.com</a><span>Responses within 12 hours</span></li>
          <li><span>Service area:</span><span>Lehigh Valley, PA & 50-mile radius</span></li>
        </ul>
        <div class="contact-assurance">
          <p>All appointments include document prep guidance and ID verification checklist.</p>
          <p class="microcopy">Prefer video consultations? Request a secure virtual session in your message.</p>
        </div>
      </div>
    </div>
  </div>
</section>
