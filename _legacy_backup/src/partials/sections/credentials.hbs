<section id="credentials" class="credentials-section surface-section surface-elevated">
  <div class="layout-container">
    <div class="credentials-centered">
      <span class="section-label">Credentials</span>

      <div class="credentials-badges" data-animate="badge">
        <img src="/assets/images/nna-badge-1.png" alt="National Notary Association Certified" class="credentials-badge" loading="lazy">
        <div class="credentials-badge--text" aria-label="$100,000 Errors and Omissions Insurance">
          <span class="badge-title">$100K</span>
          <span class="badge-subtitle">Errors &amp; Omissions</span>
        </div>
        <div class="credentials-badge--text" aria-label="Background screening cleared annually">
