                <path d="M12 30L32 14l20 16v20H12z" class="icon-stroke"></path>
                <path d="M24 50V36h16v14" class="icon-stroke"></path>
              </svg>
            </div>
            <div class="service-badge">Certified Signing Agent</div>
          </div>
          <div class="service-card-content">
            <h3>Loan Signings</h3>
            <p class="service-lead">White-glove mortgage, refinance, and HELOC closings handled with lender-specific checklists.</p>
            <ul class="service-highlights">
              <li>NNA background screened with $100k E&O coverage</li>
              <li>Scan-backs, packaging & courier drop-off upon request</li>
            </ul>
            <div class="service-meta">
              <span class="service-price">Custom quote per package</span>
              <span class="service-turnaround">Flexible scheduling</span>
            </div>
            <a href="#contact" class="service-cta service-cta--text" data-cta="loan-signing">Request Closing Support</a>
          </div>
        </article>
      </div>
