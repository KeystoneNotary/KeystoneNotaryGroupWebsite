  <div class="layout-container section-inner credentials-inner">
    <div class="credentials-layout" data-animate="credentials">
      <article class="credential-card credential-card--badge" data-animate="credential-badge">
        <div class="credential-ribbon">
          <span>Licensed & Bonded</span>
        </div>
        <img src="/assets/images/nna-badge-1.png" alt="NNA Certified Notary Signing Agent" class="cert-badge" loading="lazy">
        <div class="credential-metrics">
          <div class="metric">
            <span class="metric-value">24hr</span>
            <span class="metric-label">Response Window</span>
          </div>
          <div class="metric">
            <span class="metric-value">100K</span>
            <span class="metric-label">E&O Coverage</span>
          </div>
          <div class="metric">
            <span class="metric-value">100%</span>
            <span class="metric-label">On-time Closings</span>
          </div>
        </div>
        <ul class="credential-logo-row">
          <li class="credential-logo-pill">NNA Certified Agent</li>
          <li class="credential-logo-pill">PA Commission #1395673</li>
